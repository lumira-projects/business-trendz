---
const categories = [
  { name: 'Business', slug: 'business' },
  { name: 'Finance', slug: 'finance' },
  { name: 'Marketing', slug: 'marketing' },
  { name: 'High Tech', slug: 'high-tech' },
  { name: 'Immobilier', slug: 'immobilier' },
  { name: 'Formation', slug: 'formation' },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Business Trendz, retour à l'accueil">
      <span class="logo-text">BUSINESS<span class="logo-accent">TRENDZ</span></span>
    </a>

    <nav class="nav" aria-label="Catégories">
      <ul class="nav-list">
        {categories.map((cat) => (
          <li>
            <a href={`/c/${cat.slug}/`} class={`nav-link ${currentPath.startsWith(`/c/${cat.slug}`) ? 'active' : ''}`}>
              {cat.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/nous-contacter/" class="btn btn-primary contact-btn">Nous contacter</a>

    <button class="menu-toggle" aria-label="Ouvrir le menu" aria-expanded="false" id="menu-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <ul>
      {categories.map((cat) => (
        <li><a href={`/c/${cat.slug}/`}>{cat.name}</a></li>
      ))}
      <li><a href="/nous-contacter/" class="mobile-contact">Nous contacter</a></li>
    </ul>
  </nav>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    gap: 2rem;
  }

  .logo {
    font-family: var(--font-headline);
    font-size: 1.35rem;
    letter-spacing: -0.01em;
    line-height: 1;
    flex-shrink: 0;
  }

  .logo-text { display: inline-block; }

  .logo-accent {
    background: var(--gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-left: 0.15em;
  }

  .nav {
    display: none;
    flex: 1;
    justify-content: center;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    list-style: none;
  }

  .nav-link {
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--color-text);
    position: relative;
    padding: 0.5rem 0;
    transition: color 0.2s ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gradient-brand);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nav-link:hover::after,
  .nav-link.active::after { transform: scaleX(1); }

  .contact-btn {
    display: none;
    padding: 0.7rem 1.4rem;
    font-size: 0.85rem;
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 32px;
    padding: 4px;
  }

  .menu-toggle span {
    width: 100%;
    height: 2px;
    background: var(--color-text);
    transition: transform 0.2s ease;
  }

  .mobile-nav {
    display: none;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-nav.open { display: block; }

  .mobile-nav ul {
    list-style: none;
    padding: 1rem 0;
  }

  .mobile-nav li a {
    display: block;
    padding: 0.85rem var(--space-md);
    font-size: 1rem;
    font-weight: 500;
  }

  .mobile-contact {
    color: var(--color-bg) !important;
    background: var(--color-text);
    margin: 0.5rem var(--space-md);
    border-radius: 999px;
    text-align: center;
  }

  @media (min-width: 900px) {
    .nav { display: flex; }
    .contact-btn { display: inline-flex; }
    .menu-toggle { display: none; }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
    nav?.setAttribute('aria-hidden', String(!open));
  });
</script>
