---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recent = (await getCollection('articles'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<BaseLayout
  title="Page introuvable · Business Trendz"
  description="La page que vous cherchez n'existe pas ou a été déplacée."
>
  <section class="error-page">
    <div class="container error-container">
      <p class="error-code headline">404.</p>
      <h1 class="headline error-title">
        Cette page <span class="serif-accent">n'existe pas</span>.
      </h1>
      <p class="error-desc">
        L'URL est peut-être mal orthographiée, ou l'article a été déplacé.
        Voici quelques pistes pour retrouver ce que vous cherchez.
      </p>

      <div class="error-actions">
        <a href="/" class="btn btn-primary">Retour à l'accueil</a>
        <a href="/c/business/" class="btn btn-outline">Voir nos articles</a>
      </div>

      {recent.length > 0 && (
        <div class="error-recent">
          <h2 class="error-recent-title">Articles récents</h2>
          <ul>
            {recent.map((a) => (
              <li>
                <a href={`/${a.slug}/`}>
                  <span class="recent-title">{a.data.title}</span>
                  {a.data.categories[0] && <span class="recent-cat">{a.data.categories[0]}</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .error-container {
    max-width: var(--content-max);
    text-align: left;
  }

  .error-code {
    font-size: clamp(4rem, 12vw, 8rem);
    line-height: 1;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 1rem;
  }

  .error-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    margin-bottom: 1.25rem;
    max-width: 16ch;
  }

  .error-desc {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    max-width: 50ch;
  }

  .error-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: var(--space-2xl);
  }

  .error-recent {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }

  .error-recent-title {
    font-family: var(--font-headline);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .error-recent ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .error-recent li {
    border-bottom: 1px solid var(--color-border);
  }

  .error-recent a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 0;
    transition: padding 0.2s ease;
  }

  .error-recent a:hover {
    padding-left: 0.5rem;
  }

  .recent-title {
    font-weight: 500;
  }

  .recent-cat {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
</style>
