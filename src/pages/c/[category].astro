---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const categoryMap: Record<string, { name: string; slug: string; description: string }> = {
  'business': { name: 'Business', slug: 'business', description: 'Stratégie, gestion, croissance : toutes les tendances qui font bouger le monde du business.' },
  'entreprise': { name: 'Entreprise', slug: 'entreprise', description: 'Vie d\'entreprise, organisation, opérations : ce qu\'il faut savoir pour mieux la piloter.' },
  'entrepreneuriat': { name: 'Entrepreneuriat', slug: 'entrepreneuriat', description: 'Lancer, scaler, lever : les leçons et conseils pour entreprendre.' },
  'finance': { name: 'Finance', slug: 'finance', description: 'Financement, investissement, fiscalité : comprendre les enjeux financiers d\'aujourd\'hui.' },
  'fiscalite': { name: 'Fiscalité', slug: 'fiscalite', description: 'TVA, IS, dispositifs, niches : décrypter la fiscalité française et internationale.' },
  'formation': { name: 'Formation', slug: 'formation', description: 'Apprendre, se former, monter en compétences : les meilleures ressources et formations.' },
  'high-tech': { name: 'High Tech', slug: 'high-tech', description: 'IA, SaaS, hardware, innovations : ce qui change dans la tech business.' },
  'immobilier': { name: 'Immobilier', slug: 'immobilier', description: 'Investissement locatif, marché, fiscalité immobilière, gestion patrimoniale.' },
  'lifestyle': { name: 'Lifestyle', slug: 'lifestyle', description: 'Productivité, équilibre, lifestyle entrepreneur : vivre mieux en tant que pro.' },
  'marketing': { name: 'Marketing', slug: 'marketing', description: 'Acquisition, branding, SEO, contenu : les stratégies marketing qui marchent.' },
};

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const cats = new Set<string>();
  articles.forEach((a) => {
    a.data.categories.forEach((c) => {
      const slug = c.toLowerCase()
        .normalize('NFD').replace(/[̀-ͯ]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
      cats.add(slug);
    });
  });
  return [...cats].map((slug) => ({ params: { category: slug } }));
}

const { category } = Astro.params;
const cat = categoryMap[category!] || { name: category!, slug: category!, description: '' };

const allArticles = (await getCollection('articles'))
  .filter((a) => !a.data.draft)
  .filter((a) => a.data.categories.some((c) => {
    const cSlug = c.toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
    return cSlug === category;
  }))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const SITE_URL = 'https://business-trendz.com';
const canonicalURL = `${SITE_URL}/c/${cat.slug}/`;

// CollectionPage schema for SEO
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${cat.name} · Business Trendz`,
  description: cat.description,
  url: canonicalURL,
  inLanguage: 'fr-FR',
  numberOfItems: allArticles.length,
  hasPart: allArticles.slice(0, 10).map((a) => ({
    '@type': 'Article',
    headline: a.data.title,
    url: `${SITE_URL}/${a.slug}/`,
    datePublished: a.data.pubDate.toISOString(),
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE_URL + '/' },
    { '@type': 'ListItem', position: 2, name: cat.name, item: canonicalURL },
  ],
};
---

<BaseLayout
  title={`${cat.name} · Tous nos articles`}
  description={cat.description}
  canonicalURL={canonicalURL}
  structuredData={[collectionSchema, breadcrumbSchema]}
>
  <section class="category-hero">
    <div class="container">
      <p class="eyebrow">Catégorie</p>
      <h1 class="headline category-title">{cat.name}</h1>
      {cat.description && <p class="category-desc">{cat.description}</p>}
      <p class="category-count">{allArticles.length} article{allArticles.length > 1 ? 's' : ''}</p>
    </div>
  </section>

  <section class="category-list">
    <div class="container">
      <div class="grid grid-3">
        {allArticles.map((a) => (
          <ArticleCard
            href={`/${a.slug}/`}
            title={a.data.title}
            description={a.data.description}
            category={a.data.categories[0]}
            pubDate={a.data.pubDate}
            heroImage={a.data.heroImage}
            heroImageAlt={a.data.heroImageAlt}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .category-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .eyebrow {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .category-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    margin-bottom: 1rem;
  }

  .category-desc {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-bottom: 1rem;
  }

  .category-count {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .category-list { padding: var(--space-xl) 0; }

  .grid { display: grid; gap: 1.5rem; grid-template-columns: 1fr; }
  @media (min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .grid { grid-template-columns: repeat(3, 1fr); } }
</style>
